<script>
const SHEET_URL = 'https://docs.google.com/spreadsheets/d/e/2PACX-1vQYxFJ-AZ6u8FZaGNTV-OFbXZj_OQL2GH8BYXiwSQ6w4euTnmMIiPS-i9w7wlqESnqtHVSYfrdl1_1r/pub?gid=712742950&single=true&output=csv';

const SECTIONS = [
  { id:'S1', label:'S1  Overview',   match:/website|partner.portal|description|language|founded|employees/i },
  { id:'S2', label:'S2  Compliance', match:/gdpr|soc.?2|iso.?27001|data.residency|eu.ai.act|cra|trust.center|dpa|privacy.policy/i },
  { id:'S3', label:'S3  Product',    match:/platform|deployment|sku|license.type|user.type|user.group|os.support|version/i },
  { id:'S4', label:'S4  Pricing',    match:/discount|margin|pricing.model|pricing.freedom|erp.code|price.change|nfr|list.price|currency/i },
  { id:'S5', label:'S5  Ordering',   match:/ordering.method|order.email|invoicing|payment.term|lead.time|purchase.order/i },
  { id:'S6', label:'S6  Renewal',    match:/renewal|price.at.renewal|next.review|auto.renewal|termination|contract.end|expiry/i },
  { id:'S7', label:'S7  Support',    match:/support.email|escalation|sla|helpdesk|ticket|response.time/i },
  { id:'S8', label:'S8  Strategic',  match:/agreement|deal.reg|sub.reseller|business.case|partnership|strategic|watch|keep|grow|sunset|priority/i },
  { id:'S9', label:'S9  Contacts',   match:/primary.contact|contact.email|contact.name|contact.phone|account.manager|sales.rep/i },
];
const HEADER_RE = /^vendor$|^status$|^category$|^country$|^vendor.?type$/i;
const NAME_KEY  = 'Vendor';

let vendors = [], headers = [], active = null, selIdx = -1;

async function init() {
  setSync('loading','laden…');
  try {
    const r = await fetch(SHEET_URL);
    if (!r.ok) throw new Error();
    parseCSV(await r.text());
    document.getElementById('sbLoader').style.display = 'none';
    document.getElementById('vendorCount').textContent = vendors.length + ' vendors';
    setSync('ok','gesynchroniseerd');
    renderList();
    document.getElementById('zoek').focus();
  } catch {
    document.getElementById('sbLoader').style.display = 'none';
    document.getElementById('sbErr').style.display = 'block';
    setSync('err','fout bij laden');
  }
}

function setSync(s,t) { document.getElementById('syncDot').className='sync-dot '+s; document.getElementById('syncLabel').textContent=t; }

function parseCSV(text) {
  const lines = text.trim().split('\n').filter(l=>l.trim());
  const sep = lines[0].split(';').length > lines[0].split(',').length ? ';' : ',';
  headers = lines[0].split(sep).map(h=>h.trim().replace(/\r/g,''));
  vendors = lines.slice(1).map(line => {
    const vals = parseLine(line,sep); const o={};
    headers.forEach((h,i)=>o[h]=(vals[i]||'').trim().replace(/\r/g,''));
    return o;
  }).filter(v=>v[NAME_KEY]&&v[NAME_KEY].trim());
}

function parseLine(line,sep) {
  const res=[]; let cur='',q=false;
  for(const c of line){ if(c==='"')q=!q; else if(c===sep&&!q){res.push(cur);cur='';}else cur+=c; }
  res.push(cur); return res;
}

function renderList(filter='') {
  selIdx=-1;
  const lq=filter.toLowerCase();
  const hits=lq?vendors.filter(v=>(v[NAME_KEY]||'').toLowerCase().includes(lq)):vendors;
  const el=document.getElementById('resultsList');
  if(!hits.length){el.innerHTML='<div class="no-results">Geen vendors gevonden</div>';return;}
  el.innerHTML=hits.slice(0,80).map(v=>{
    const name=v[NAME_KEY], status=v['Status']||'', cat=v['Category']||'', country=v['Country']||'';
    const sub=[cat,country].filter(Boolean).join(' · ');
    const isOn=active&&active[NAME_KEY]===name;
    return `<div class="result-item${isOn?' active':''}" data-v="${esc(name)}">
      <div class="r-left">
        <span class="r-name">${lq?hl(name,lq):name}</span>
        ${sub?`<span class="r-sub">${sub}</span>`:''}
      </div>
      ${status?`<span class="r-tag">${status}</span>`:''}
    </div>`;
  }).join('');
  el.querySelectorAll('.result-item').forEach(e=>e.addEventListener('click',()=>pick(e.dataset.v)));
}

document.getElementById('zoek').addEventListener('input',e=>renderList(e.target.value));
document.getElementById('zoek').addEventListener('keydown',e=>{
  const items=document.querySelectorAll('.result-item'); if(!items.length)return;
  if(e.key==='ArrowDown'){e.preventDefault();selIdx=Math.min(selIdx+1,items.length-1);markSel(items);}
  else if(e.key==='ArrowUp'){e.preventDefault();selIdx=Math.max(selIdx-1,0);markSel(items);}
  else if(e.key==='Enter'&&selIdx>=0)items[selIdx].click();
  else if(e.key==='Escape')e.target.blur();
});
function markSel(items){items.forEach((e,i)=>e.classList.toggle('sel',i===selIdx));}
function hl(t,q){const i=t.toLowerCase().indexOf(q);return i<0?t:t.slice(0,i)+'<strong>'+t.slice(i,i+q.length)+'</strong>'+t.slice(i+q.length);}
function esc(s){return(s||'').replace(/"/g,'&quot;');}

function pick(name) {
  const v=vendors.find(x=>x[NAME_KEY]===name); if(!v)return;
  active=v; renderList(document.getElementById('zoek').value); renderPassport(v);
}

function renderPassport(v) {
  const merged={...v,...getEdits(v[NAME_KEY])};
  document.getElementById('phName').textContent=merged[NAME_KEY]||'—';
  const status=merged['Status']||'', cat=merged['Category']||'', country=merged['Country']||'', type=merged['Vendor Type']||merged['Vendor type']||'';
  document.getElementById('phTags').innerHTML=[status,cat,country,type].filter(Boolean).map(t=>{
    const cls=/actief|active/i.test(t)?'at':/inactief|inactive/i.test(t)?'it':'';
    return `<span class="fh-tag ${cls}">${t}</span>`;
  }).join('');
  markUnsaved(v[NAME_KEY]);

  const hdrCols=new Set(headers.filter(h=>HEADER_RE.test(h)));
  const buckets=SECTIONS.map(s=>({...s,keys:[]}));
  const rest={id:'SX',label:'Overige',keys:[]};
  headers.forEach(h=>{
    if(h===NAME_KEY||hdrCols.has(h))return;
    const i=SECTIONS.findIndex(s=>s.match.test(h));
    i>=0?buckets[i].keys.push(h):rest.keys.push(h);
  });
  const secs=[...buckets,...(rest.keys.length?[rest]:[])].filter(s=>s.keys.length);

  document.getElementById('sectionTabs').innerHTML=secs.map((s,i)=>
    `<button class="stab${i===0?' on':''}" data-id="${s.id}" onclick="switchTab('${s.id}')">${s.label}</button>`
  ).join('');

  document.getElementById('ficheBody').innerHTML=secs.map((s,i)=>
    `<div class="sec-panel${i===0?' on':''}" id="sp-${s.id}">
      <div class="section-header"><span class="section-label">${s.label}</span></div>
      ${s.keys.map(k=>renderRow(k,merged[k],v[NAME_KEY])).join('')}
    </div>`
  ).join('');

  document.getElementById('emptyState').style.display='none';
  document.getElementById('fiche').classList.add('visible');
  document.getElementById('passportArea').scrollTo(0,0);
  renderMdPreview(merged);
}

function switchTab(id) {
  document.querySelectorAll('.stab').forEach(b=>b.classList.toggle('on',b.dataset.id===id));
  document.querySelectorAll('.sec-panel').forEach(p=>p.classList.toggle('on',p.id==='sp-'+id));
}

function renderRow(key,rawVal,vName) {
  const val=(rawVal||'').trim(), empty=!val;
  const isURL=/^https?:\/\//i.test(val), isBool=/^(yes|no|ja|nee|true|false|✓|✗|x)$/i.test(val);
  const isMono=/erp.?code|iban|discount|margin|sku|code/i.test(key);
  const attrs=`contenteditable="true" data-key="${esc(key)}" data-v="${esc(vName)}" onblur="saveEdit(this)"`;
  let inner;
  if(empty){ inner=`<span class="field-val empty" ${attrs}></span>`; }
  else if(isBool){ const yes=/^(yes|ja|true|✓|x)$/i.test(val); inner=`<span class="field-val ${yes?'bool-yes':'bool-no'}" ${attrs}>${val}</span>`; }
  else if(isURL){ inner=`<span class="url-wrap"><span class="field-val${isMono?' mono':''}" ${attrs}>${val}</span><a class="url-open" href="${val}" target="_blank" rel="noopener" title="open">↗</a></span>`; }
  else{ inner=`<span class="field-val${isMono?' mono':''}" ${attrs}>${val}</span>`; }
  const copyBtn=val?`<button class="copy-btn" onclick="cpField(this,${JSON.stringify(val)})"><svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>kopieer</button>`:'<span></span>';
  return `<div class="field-row"><span class="field-key">${key}</span>${inner}${copyBtn}</div>`;
}

function skey(n){return 'vedits_'+n.toUpperCase().replace(/\s+/g,'_');}
function getEdits(n){try{return JSON.parse(localStorage.getItem(skey(n))||'{}');}catch{return {};}}
function saveEdit(el){
  if(!active)return;
  const key=el.dataset.key, vName=el.dataset.v, val=el.innerText.trim(), orig=active[key]||'';
  const edits=getEdits(vName);
  if(!val||val===orig)delete edits[key]; else edits[key]=val;
  localStorage.setItem(skey(vName),JSON.stringify(edits));
  markUnsaved(vName);
  renderMdPreview({...active,...getEdits(vName)});
}
function resetEdits(){if(!active)return;localStorage.removeItem(skey(active[NAME_KEY]));renderPassport(active);}
function markUnsaved(n){document.getElementById('unsavedDot').style.display=Object.keys(getEdits(n)).length?'block':'none';}

function buildMd(merged){
  const hdrCols=new Set(headers.filter(h=>HEADER_RE.test(h)));
  const buckets=SECTIONS.map(s=>({...s,keys:[]})); const rest={id:'SX',label:'Overige',keys:[]};
  headers.forEach(h=>{if(h===NAME_KEY||hdrCols.has(h))return;const i=SECTIONS.findIndex(s=>s.match.test(h));i>=0?buckets[i].keys.push(h):rest.keys.push(h);});
  const secs=[...buckets,...(rest.keys.length?[rest]:[])].filter(s=>s.keys.length);
  let md=`## ${merged[NAME_KEY]||'—'}\n**Status:** ${merged['Status']||'—'}  ·  **Category:** ${merged['Category']||'—'}  ·  **Country:** ${merged['Country']||'—'}\n\n`;
  secs.forEach(s=>{md+=`### ${s.label}\n`;s.keys.forEach(k=>{const v=(merged[k]||'').trim();if(v)md+=`**${k}:** ${v}\n`;});md+='\n';});
  return md.trim();
}
function renderMdPreview(merged){
  document.getElementById('mdBody').innerHTML=buildMd(merged)
    .replace(/^## .+$/gm,m=>`<span class="mh">${m}</span>`)
    .replace(/^### .+$/gm,m=>`<span class="ms">${m}</span>`)
    .replace(/\*\*([^*]+)\*\*/g,(_,k)=>`<span class="ms">**${k}**</span>`);
}
function copyMd(){
  if(!active)return;
  navigator.clipboard.writeText(buildMd({...active,...getEdits(active[NAME_KEY])})).then(()=>{
    ['mdBtn','mdCopyBtn'].forEach(id=>{
      const btn=document.getElementById(id); if(!btn)return;
      const orig=btn.textContent;
      btn.textContent='✓ gekopieerd'; btn.classList.add(id==='mdBtn'?'ok':'copied');
      setTimeout(()=>{btn.textContent=orig;btn.classList.remove('ok','copied');},2000);
    });
  });
}
function cpField(btn,val){
  navigator.clipboard.writeText(val).then(()=>{
    btn.classList.add('copied');
    btn.innerHTML=`<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 12 4 10"/></svg>gekopieerd`;
    setTimeout(()=>{btn.classList.remove('copied');btn.innerHTML=`<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>kopieer`;},2000);
  });
}

init();
</script>

